# ══════════════════════════════════════════════════════════════
# MAF SDLC Platform — Environment Configuration
# ══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#     cp .env.example .env
#
# REQUIRED: Azure AI Foundry credentials (the platform won't start without these)
# OPTIONAL: GitHub and Bing keys (agents work without them, just less capable)
#
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# REQUIRED: Azure AI Foundry - Model Deployments
# ──────────────────────────────────────────────────────────────
#
# 1. Go to Azure AI Foundry (https://ai.azure.com)
# 2. Create a Hub → Create a Project
# 3. Deploy models (GPT-4o, GPT-4o-mini, etc.)
# 4. Copy the endpoint URL and API key from the deployment
#

# Your Azure OpenAI endpoint (same for all deployments under one resource)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-api-key-here

# API version
AZURE_OPENAI_API_VERSION=2024-10-21

# Deployment names (the names YOU gave each deployment in AI Foundry)
ORCHESTRATOR_DEPLOYMENT=gpt-4o
REQUIREMENTS_DEPLOYMENT=gpt-4o
ARCHITECTURE_DEPLOYMENT=gpt-4o
PLANNING_DEPLOYMENT=gpt-4o-mini


# ──────────────────────────────────────────────────────────────
# OPTIONAL: GitHub Token (enables GitHub MCP — repo reading)
# ──────────────────────────────────────────────────────────────
#
# Allows agents to read files from GitHub repos for existing project analysis.
# Without this, the "existing project" use case still works but agents rely
# on your description instead of reading the actual code.
#
# Create a token: GitHub → Settings → Developer Settings → Personal Access Tokens
# Required scopes: repo (read), read:org (if using org repos)
#
GITHUB_TOKEN=


# ──────────────────────────────────────────────────────────────
# OPTIONAL: Bing Search API Key (enables web search tool)
# ──────────────────────────────────────────────────────────────
#
# Allows agents to search the web for technology benchmarks, competitor
# analysis, and best practices. Without this, agents use their built-in
# knowledge (still works, just less current).
#
# Get a key: Azure Portal → Create "Bing Search v7" resource → Keys
#
BING_SEARCH_API_KEY=

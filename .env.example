# ──────────────────────────────────────────────────────────────
# Azure AI Foundry - Model Deployments
# ──────────────────────────────────────────────────────────────
#
# 1. Go to Azure AI Foundry (https://ai.azure.com)
# 2. Create a Hub → Create a Project
# 3. Deploy models (GPT-4o, GPT-4o-mini, etc.)
# 4. Copy the endpoint URL and API key from the deployment
# 5. Copy this file to .env and fill in your values:
#       cp .env.example .env
#
# ──────────────────────────────────────────────────────────────

# Your Azure OpenAI endpoint (same for all deployments under one resource)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI API key
AZURE_OPENAI_API_KEY=your-api-key-here

# API version (use the latest stable version)
AZURE_OPENAI_API_VERSION=2024-10-21

# ──────────────────────────────────────────────────────────────
# Deployment Names (as created in Azure AI Foundry)
# ──────────────────────────────────────────────────────────────
# These are the names YOU gave your deployments in AI Foundry.
# Example: if you deployed GPT-4o and named it "gpt-4o", use that.

# Main model for orchestrator and complex reasoning
ORCHESTRATOR_DEPLOYMENT=gpt-4o

# Model for Requirements Agent
REQUIREMENTS_DEPLOYMENT=gpt-4o

# Model for Architecture Agent
ARCHITECTURE_DEPLOYMENT=gpt-4o

# Model for Planning Agent (can use a cheaper model)
PLANNING_DEPLOYMENT=gpt-4o-mini
